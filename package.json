{
  "name": "webflow-code-editor",
  "displayName": "Webflow Code Editor",
  "publisher":"raymondcamden",
  "description": "Lets you edit custom code for Webflow sites in VSC",
  "icon": "media/webflow-code-editor-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Webflow-Examples/webflow-code-editor.git"
  },
  "bugs": {
    "url": "https://github.com/Webflow-Examples/webflow-code-editor/issues"
  },
  "homepage": "https://github.com/Webflow-Examples/webflow-code-editor#readme",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
"contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-tree-extension-container",
          "title": "Webflow Code Editor",
          "icon": "media/webflow-mono.svg"
        }
      ]
    },
    "views": {
      "my-tree-extension-container": [
        {
          "id": "my-auth-tree-view",
          "name": "Sites"
        }
      ]
    },
    "commands": [
        {
            "command": "webflow-code-editor.login",
            "title": "Login to Webflow"
        }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
